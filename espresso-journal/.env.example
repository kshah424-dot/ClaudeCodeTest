# =============================================================================
# Confluence Cloud (required to publish dial entries)
# =============================================================================
#
# 1) Site URL — use your Atlassian cloud site root only:
#    https://YOUR-SITE.atlassian.net
#    (You can paste a longer browser URL; the app keeps only the host.)
#
# 2) Email — the same Atlassian account you use to log into Confluence.
#
# 3) API token — create at:
#    https://id.atlassian.com/manage-profile/security/api-tokens
#    (Label e.g. "espresso-journal"; copy the token once into CONFLUENCE_API_TOKEN.)
#
# 4) Space key — short key from the space URL:
#    .../wiki/spaces/TEAM/...  →  TEAM
#    Or: Space settings → Space details → Key
#
# 5) Parent page (optional) — new dial pages appear under this page.
#    Open the page → ••• menu → "Copy link" or check URL .../pages/123456789/...
#    The number is the page ID (use digits only).
#
CONFLUENCE_BASE_URL=https://your-site.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=TEAM
CONFLUENCE_PARENT_PAGE_ID=

# =============================================================================
# Server
# =============================================================================
HOST=0.0.0.0
PORT=8000

# Optional: shared secret for Telegram / email webhooks (?secret=...)
WEBHOOK_SECRET=
