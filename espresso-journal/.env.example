# Confluence (Cloud)
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACE_KEY=TEAM
# Optional: numeric page ID to create child pages under
CONFLUENCE_PARENT_PAGE_ID=

# Server
HOST=0.0.0.0
PORT=8000
# Shared secret for Telegram and generic webhooks (optional but recommended)
WEBHOOK_SECRET=

# Telegram: set your bot webhook to https://your-host/webhooks/telegram?secret=WEBHOOK_SECRET
